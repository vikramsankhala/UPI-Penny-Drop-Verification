# Systemd service for UPI Penny Drop app
# Place in /etc/systemd/system/penny-drop.service

[Unit]
Description=UPI Penny Drop Verification
After=network.target

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/var/www/penny-drop
Environment="PATH=/var/www/penny-drop/venv/bin"
ExecStart=/var/www/penny-drop/venv/bin/gunicorn --bind 127.0.0.1:5000 --workers 2 --threads 4 --timeout 60 app:app
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
