# Razorpay (RazorpayX) credentials for LIVE penny drop verification
# Get these from: https://dashboard.razorpay.com/app/keys (switch to LIVE mode)
# Full setup guide: see RAZORPAY_SETUP.md
#
# IMPORTANT: Account validation is NOT available in test mode.
# You need RazorpayX Lite in live mode.

# Live API keys from Dashboard → Settings → API Keys (Live mode)
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_live_secret_key

# Your RazorpayX Lite account number (from x.razorpay.com → Account/Settings)
# This is the account from which ₹1 is deducted for each penny drop
RAZORPAY_SOURCE_ACCOUNT=7878780080316316
